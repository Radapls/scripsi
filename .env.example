# Git provider: "gitlab" or "github" (default: gitlab)
GIT_PROVIDER=gitlab

# GitLab credentials (required if GIT_PROVIDER=gitlab)
GITLAB_URL=your_gitlab_url
GITLAB_TOKEN=your_personal_access_token_here
GITLAB_USERNAME=your_gitlab_username

# GitHub credentials (required if GIT_PROVIDER=github)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USERNAME=your_github_username

# Jira credentials
JIRA_URL=your_jira_url
JIRA_TOKEN=your_jira_token
JIRA_EMAIL=your_email

# Docs repo config
DOCS_GROUP=your_username_group
DOCS_REPO_PREFIX=scripsi # Change if you want to have another prefix